[Unit]
Description=tlsgate TLS Fingerprint Proxy
After=network.target

[Service]
Type=simple
User=tlsgate
Group=tlsgate
{# routes: list of {listen, backend}. Falls back to the mail defaults so
   existing inventories that set imap_backend/smtp_backend keep working. #}
ExecStart=/usr/local/bin/tlsgate serve \
{% for r in routes | default([{'listen': imap_listen | default('[::]:993'), 'backend': imap_backend}, {'listen': smtp_listen | default('[::]:465'), 'backend': smtp_backend}]) %}
  --route {{ r.listen }}={{ r.backend }} \
{% endfor %}
  --db /var/lib/tlsgate/db.sqlite \
  --fingerprint {{ fingerprint | default('ja3') }} \
  {% if reset_fingerprints | default(false) | bool %}--reset-fingerprints {% endif %}{% if allow_unknown | default(false) | bool %}--allow-unknown{% endif %}

Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# Headroom above 2x maxConcurrentConns (1024) for client+backend sockets
# plus the SQLite database, WAL, and journal handles.
LimitNOFILE=8192

AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ProtectKernelTunables=true
ProtectControlGroups=true
PrivateDevices=true
PrivateTmp=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
ReadWritePaths=/var/lib/tlsgate

[Install]
WantedBy=multi-user.target
